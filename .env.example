# Encryption key for provider API keys. Auto-generated on first run if empty.
# Set this for persistent encryption across container restarts.
ENCRYPTION_KEY=

# Admin password for the web UI. Required in production (NODE_ENV=production).
# Defaults to "admin" in development mode with a warning.
ADMIN_PASSWORD=

# Proxy base URL shown in endpoint detail view. Overrides auto-detection.
# Set this when running behind a reverse proxy (e.g. https://api.example.com/v1).
PROXY_BASE_URL=
